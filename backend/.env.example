# ==============================================================================
# FoundrAI Backend Environment Configuration (Phase 2)
# ==============================================================================

# Application Environment
ENV_NAME=development
DEBUG=true
PROJECT_NAME="FoundrAI Backend"

# PostgreSQL Configuration
# Note: For running via Docker Compose, use POSTGRES_HOST=postgres
# For running locally on host machine, use POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=foundrai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional override. If not set, DATABASE_URL is assembled dynamically
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foundrai
